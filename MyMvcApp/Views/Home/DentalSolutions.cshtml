 @{
    ViewData["Title"] = "pricing";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Dentalsolutions.css">
}
 <section class="hero-section d-flex align-items-center">
            <div class="container text-center">

                <h1 class="hero-title">
                    Dental Solutions & Treatment Care
                </h1>

                <p class="hero-text">
                    We provide comprehensive and reliable treatment solutions
                    for a wide range of dental problems.
                </p>

                <a href="#" class="btn hero-btn px-5 py-2">
                    Book an Appointment
                </a>

            </div>
        </section>
        <!-- Dental Solutions Section -->
        <section class="container py-5">

            <div class="text-center mb-4">
                <h2 class="fw-bold">Dental Solutions</h2>
                <p class="text-muted">
                    Effective treatment options for common dental problems.
                </p>
            </div>

            <div class="row g-4">

                <!-- Solution Card -->
                <div class="col-md-4">
                    <div class="solution-card">
                        <div class="solution-icon">
                            <i class="bi bi-emoji-frown"></i>
                        </div>

                        <h5 class="fw-bold">Tooth Decay Treatment</h5>

                        <p>
                            Professional fillings and restoration procedures to
                            treat cavities
                            and protect tooth structure.
                        </p>

                        <a href="#" class="solution-link">Learn More</a>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="solution-card">
                        <div class="solution-icon">
                            <i class="bi bi-bandaid"></i>
                        </div>

                        <h5 class="fw-bold">Gum Disease Care</h5>

                        <p>
                            Deep cleaning and periodontal therapy to restore gum
                            health
                            and prevent complications.
                        </p>

                        <a href="#" class="solution-link">Learn More</a>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="solution-card">
                        <div class="solution-icon">
                            <i class="bi bi-braces"></i>
                        </div>

                        <h5 class="fw-bold">Teeth Misalignment Fix</h5>

                        <p>
                            Orthodontic braces and aligners designed to improve
                            bite function
                            and smile alignment.
                        </p>

                        <a href="#" class="solution-link">Learn More</a>
                    </div>
                </div>
                <!-- Tooth Sensitivity -->
                <div class="col-md-4">
                    <div class="solution-card">

                        <div class="solution-icon">
                            <i class="bi bi-emoji-dizzy"></i>
                        </div>

                        <h5 class="fw-bold">Tooth Sensitivity Relief</h5>

                        <p>
                            Desensitizing treatments and enamel strengthening
                            solutions to reduce
                            pain while eating and drinking.
                        </p>

                        <a href="#" class="solution-link">Learn More</a>
                    </div>
                </div>

                <!-- Cosmetic Smile Enhancement -->
                <div class="col-md-4">
                    <div class="solution-card">

                        <div class="solution-icon">
                            <i class="bi bi-emoji-smile"></i>
                        </div>

                        <h5 class="fw-bold">Cosmetic Smile Enhancement</h5>

                        <p>
                            Whitening, veneers, and cosmetic reshaping to
                            improve smile appearance
                            and boost confidence.
                        </p>

                        <a href="#" class="solution-link">Learn More</a>
                    </div>
                </div>

                <!-- Dental Implants -->
                <div class="col-md-4">
                    <div class="solution-card">

                        <div class="solution-icon">
                            <i class="bi bi-hospital"></i>
                        </div>

                        <h5 class="fw-bold">Dental Implants & Replacement</h5>

                        <p>
                            Permanent and durable implant solutions for missing
                            teeth to restore
                            function and natural smile aesthetics.
                        </p>

                        <a href="#" class="solution-link">Learn More</a>
                    </div>
                </div>

            </div>

        </section>
        <!--appointment container-->
        <section class="container my-5">

            <div class="row align-items-stretch g-0 no-gap">

                <!-- Text Column (With Background & Circles) -->
                <div class="col-md-7">
                    <div class="appointment-box p-5">

                        <h3 class="fw-bold text-white">
                            Not sure which treatment suits your case?
                        </h3>

                        <p class="text-white-50">
                            Book a consultation and our doctors will guide you
                            to the best solution.
                        </p>

                        <a class="btn btn-light px-4 fw-semibold">
                            Book an Appointment
                        </a>

                    </div>
                </div>

                <!-- Image Column -->
                <div class="col-md-5">
                    <img
                        src="~/img/solutions1.jpg"
                        class="equal-img">
                </div>

            </div>

        </section>