<section id="book-appointment" class="container appointment-bar">

    @if (TempData["AppointmentSuccess"] != null)
    {
        <div class="alert alert-success">@TempData["AppointmentSuccess"]</div>
    }
    @if (TempData["AppointmentError"] != null)
    {
        <div class="alert alert-danger">
            @TempData["AppointmentError"]
            @if (TempData["AppointmentErrors"] != null)
            {
                <div><small>@TempData["AppointmentErrors"]</small></div>
            }
        </div>
    }

    <form asp-controller="Appointment" asp-action="Create" method="post">
        <div class="row g-4 align-items-end">

            <div class="col-md-2">
                <label class="form-label fw-semibold">Name</label>
                <input type="text" name="Name" class="form-control form-field" placeholder="Your Name" required>
            </div>

            <div class="col-md-2">
                <label class="form-label fw-semibold">Email</label>
                <input type="email" name="Email" class="form-control form-field" placeholder="Your Email" required>
            </div>
            <div class="col-md-2">
    <label class="form-label fw-semibold">Gender</label>
    <select name="Gender" class="form-select form-field" required>
        <option value="">Select Gender</option>
        <option>Male</option>
        <option>Female</option>
        <option>Other</option>
    </select>
</div>

            <div class="col-md-2">
                <label class="form-label fw-semibold">Service</label>
                <select name="Service" class="form-select form-field" required>
                    <option value="">Select Service</option>
                    <option>Dental Cleaning</option>
                    <option>Dental Implants</option>
                    <option>Orthodontics</option>
                    <option>Cosmetic Dentistry</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label fw-semibold">Date</label>
               <input type="date" name="AppointmentDate" class="form-control form-field" min="@DateTime.Now.ToString("yyyy-MM-dd")" required>
            </div>

            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn make-btn w-100">
                    Make Appointment
                </button>
            </div>

        </div>
    </form>

</section>