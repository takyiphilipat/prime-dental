@model MyMvcApp.Models.Post
@{
    ViewData["Title"] = "New Post";
    Layout = "_AdminLayout";
}

<h2>New Post</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label class="form-label">Title</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Content</label>
        <textarea asp-for="Content" class="form-control" rows="6"></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Image URL (optional)</label>
        <input asp-for="ImageUrl" class="form-control" placeholder="/img/blog1.jpg" />
    </div>

    <div class="mb-3">
        <label class="form-label">Published Date</label>
        <input asp-for="PublishedDate" type="date" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Create Post</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
